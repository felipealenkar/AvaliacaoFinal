implementation

{$R *.dfm}

procedure TFrmPrincipal.AbrirFormNoPnlDesktop(PForm: TForm);
begin
  LimparPnlDesktop;
  PForm.Parent := PnlDesktop;
  PForm.Show;
end;

procedure TFrmPrincipal.AtualizarBotoes;
begin
  SbtnCultura.Enabled := True;
  SbtnTipoCultura.Enabled := True;
  SbtnTipoManejo.Enabled := True;
  SbtnManejo.Enabled := True;


  if PnlDesktop.ControlCount > 1 then
  begin
    if PnlDesktop.Controls[1] is TFrmTipoCultura then
      SbtnTipoCultura.Enabled := False;
    if PnlDesktop.Controls[1] is TFrmCultura then
      SbtnCultura.Enabled := False;
    if PnlDesktop.Controls[1] is TFrmTipoManejo then
      SbtnTipoManejo.Enabled := False;
    if PnlDesktop.Controls[1] is TFrmManejo then
      SbtnManejo.Enabled := False;
    // ... outros ifs aqui
  end;
end;

procedure TFrmPrincipal.BuscarNovaCuriosidade;
begin
  FBuscaEmAndamento := True;
  TThread.CreateAnonymousThread(
    procedure
    var
      LCurio: String;
    begin
      try
        // Busca a dica na sua API (Trefle/Gemini)
        LCurio := FCulturaApiController.ObterCuriosidade;

        TThread.Synchronize(nil,
          procedure
          begin
            if LCurio <> '' then
              FProximoTexto := LCurio; // Alimenta o buffer para a próxima troca
          end);
      finally
        FBuscaEmAndamento := False;
      end;
    end).Start;
end;

procedure TFrmPrincipal.ExecutarLetreiro(PPrimeiraExecucao: Boolean);
begin
  if PPrimeiraExecucao then
  begin
    FCuriosidades := '!!! Bem-vindo ao HortiSys !!! - O parceiro perfeito para a sua horta.';
    FProximoTexto := EmptyStr; // Limpa o buffer inicial
    FXPos := PbCuriosidades.Width * 3; //Define posiçăo onde o texto vai aparecer
    Exit;
  end;

  Dec(FXPos, 5); //Regula velocidade

  // Quando o texto passar totalmente ŕ esquerda
  if FXPos < -PbCuriosidades.Canvas.TextWidth(FCuriosidades) then
  begin

    FXPos := PbCuriosidades.Width * 3; //Define posiçăo onde o texto vai aparecer

    if (FProximoTexto <> '') then // Tira o texto da "sala de espera" e coloca no letreiro
    begin
       FCuriosidades := FProximoTexto;
       FProximoTexto := EmptyStr; // Limpa para garantir que a próxima troca só ocorra com dado novo
    end;

    if not FBuscaEmAndamento then
       BuscarNovaCuriosidade; // Já dispara a busca da PRÓXIMA dica para quando esta acabar
  end;

  PbCuriosidades.Invalidate;
end;

procedure TFrmPrincipal.FormCreate(Sender: TObject);
begin
  FCulturaApiController := TProviderFactory.NewCulturaApiController;
end;

procedure TFrmPrincipal.FormDestroy(Sender: TObject);
begin
  FCulturaApiController.Free;
end;

procedure TFrmPrincipal.FormShow(Sender: TObject);
begin
  ExecutarLetreiro(True);
  TmrCuriosidade.Enabled := True;
end;

procedure TFrmPrincipal.LimparPnlDesktop;
var
  I: Integer;
begin
  for I := PnlDesktop.ControlCount - 1 downto 1 do
    if (PnlDesktop.Controls[I] is TForm) and
       not (csDestroying in PnlDesktop.Controls[I].ComponentState) then
      PnlDesktop.Controls[I].Free;
end;

procedure TFrmPrincipal.PbCuriosidadesPaint(Sender: TObject);
begin
  PbCuriosidades.Canvas.FillRect(PbCuriosidades.ClientRect);
  PbCuriosidades.Canvas.Brush.Style := bsClear;

  // Desenha o texto na posiçăo atual (FXPos)
  PbCuriosidades.Canvas.TextOut(FXPos, 5,  FCuriosidades);
end;

