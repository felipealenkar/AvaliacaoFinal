unit Controller.Cultura;

interface

uses
  System.SysUtils, System.Generics.Collections, System.Classes,
  Model.Cultura, Repository.Cultura, Service.Cultura;

type
  TCulturaController = class
  private
    FCulturaService: TCulturaService;
  public
    constructor Create(PCulturaRepository: TCulturaRepository);
    destructor Destroy; override;

    procedure InserirCultura(PNome: string; PIdTipoCultura: Integer; PDataPlantio: TDateTime; PAtivo: Boolean; PFoto: TMemoryStream);
    procedure AtualizarCultura(PId: Integer; PNome: string; PIdTipoCultura: Integer; PDataPlantio: TDateTime; PAtivo: Boolean; PFoto: TMemoryStream);
    procedure ExcluirCultura(PId: Integer);
    function ListarCulturas(POrdenacao: string): TObjectList<TCultura>;
    function PesquisarCulturas(PBusca, POrdenacao: string): TObjectList<TCultura>;
    function ObterCulturaPorId(PId: Integer): TCultura;
  end;

implementation

{ TCulturaController }

constructor TCulturaController.Create(PCulturaRepository: TCulturaRepository);
begin
  FCulturaService := TCulturaService.Create(PCulturaRepository);
end;

destructor TCulturaController.Destroy;
begin
  FCulturaService.Free;
  inherited;
end;

procedure TCulturaController.InserirCultura(PNome: string; PIdTipoCultura: Integer;
                                            PDataPlantio: TDateTime; PAtivo: Boolean; PFoto: TMemoryStream);
begin
  if Trim(PNome).IsEmpty then
    raise Exception.Create('Nome da cultura n„o pode estar vazio.');

  FCulturaService.Inserir(PNome, PIdTipoCultura, PDataPlantio, PAtivo, PFoto);
end;

procedure TCulturaController.AtualizarCultura(PId: Integer; PNome: string; PIdTipoCultura: Integer;
                                              PDataPlantio: TDateTime; PAtivo: Boolean; PFoto: TMemoryStream);
begin
  if Trim(PNome).IsEmpty then
    raise Exception.Create('Nome da cultura n„o pode estar vazio.');

  FCulturaService.Atualizar(PId, PNome, PIdTipoCultura, PDataPlantio, PAtivo, PFoto);
end;

procedure TCulturaController.ExcluirCultura(PId: Integer);
begin
  FCulturaService.Excluir(PId);
end;

function TCulturaController.ListarCulturas(POrdenacao: string): TObjectList<TCultura>;
begin
  Result := FCulturaService.Listar(POrdenacao);
end;

function TCulturaController.PesquisarCulturas(PBusca, POrdenacao: string): TObjectList<TCultura>;
begin
  Result := FCulturaService.Pesquisar(PBusca, POrdenacao);
end;

function TCulturaController.ObterCulturaPorId(PId: Integer): TCultura;
begin

end;

end.
