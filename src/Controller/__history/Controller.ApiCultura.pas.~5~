unit Controller.ApiCultura;

interface

uses
  Service.ApiCultura,
  System.SysUtils,
  System.Generics.Collections,
  System.Classes;

type
  TApiController = class
  private
    FApiCulturaService: TApiCulturaService;
  public
    constructor Create(PApiCulturaService: TApiCulturaService);
    destructor Destroy; override;
  function ConsultarFotoApi(PNome: String): string;
  end;

implementation

{ TCulturaService }

function TApiController.ConsultarFotoApi(PNome: String): string;
begin
  FApiCulturaService.ConsultarFotoApi(PNome);
end;

constructor TApiController.Create(PApiCulturaService: TApiCulturaService);
begin
  inherited Create;
  FApiCulturaService := FApiCulturaService;
end;

destructor TApiController.Destroy;
begin
  FApiCulturaService.Free;
  inherited;
end;

end.
